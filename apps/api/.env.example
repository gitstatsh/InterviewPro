DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_platform"
REDIS_URL="redis://localhost:6379"

BETTER_AUTH_SECRET="your-secret-key-min-32-chars-change-in-production"
BETTER_AUTH_URL="http://localhost:3001"

FRONTEND_URL="http://localhost:3000"

RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="noreply@yourdomain.com"

ANTHROPIC_API_KEY="sk-ant-your-key"

PORT=3001
NODE_ENV="development"

# COBRA core engine. Keep disabled unless running the coverage/impact service.
COBRA_ENABLED="0"
COBRA_AUTO_RUN="0"
COBRA_TOKEN="replace-with-a-long-random-webhook-token"
# COBRA_STORAGE_DIR="C:/absolute/path/to/shared/cobra-storage"
