NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_AUTH_URL="http://localhost:3001"
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-change-in-production"

# Hosted Playwright target. No local web/API servers are started.
E2E_BASE_URL="https://app.techinterview.co.in"
E2E_BROWSER_CHANNEL="chrome"
E2E_HEADED="true"

# Optional real-login Playwright test credentials. Set these in the shell
# running Playwright; never commit real values.
E2E_LOGIN_EMAIL=""
E2E_LOGIN_PASSWORD=""

# Deployment-only COBRA metadata. Vercel supplies VERCEL_GIT_COMMIT_SHA
# automatically; other hosts should set COBRA_COMMIT_SHA explicitly.
COBRA_SOURCE_MAPS="0"
COBRA_COMMIT_SHA=""
